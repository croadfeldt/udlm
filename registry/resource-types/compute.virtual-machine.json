{
  "$id": "https://udlm.dev/registry/udlm/0.1/Compute.VirtualMachine/0.1.0",
  "conforms_to": "udlm/0.1",
  "uuid": "692b9112-5944-4d3a-93b3-cfd6e93299c7",
  "resource_type": "Compute.VirtualMachine",
  "version": "0.1.0",
  "family": "Resource",
  "entity_type": "Infrastructure Resource",
  "portability": "portable",
  "status": "active",
  "metadata": {
    "display_name": "Virtual Machine",
    "description": "A virtual compute instance with CPU, memory, a guest OS, and optional attached disks and network interfaces.",
    "maintainer": "udlm-registry",
    "origination_timestamp": "2026-06-17T18:31:11Z"
  },
  "spec": {
    "type": "object",
    "required": [
      "vcpu",
      "memory",
      "guest_os"
    ],
    "properties": {
      "vcpu": {
        "type": "object",
        "required": [
          "count"
        ],
        "properties": {
          "count": {
            "type": "integer",
            "minimum": 1,
            "description": "Number of virtual CPUs."
          }
        }
      },
      "memory": {
        "type": "object",
        "required": [
          "size"
        ],
        "properties": {
          "size": {
            "type": "string",
            "pattern": "^[0-9]+(MB|GB|TB)$",
            "description": "Memory allocation, e.g. 16GB."
          }
        }
      },
      "guest_os": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "Guest OS image identifier, e.g. rhel-9."
          }
        }
      },
      "disks": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "size"
          ],
          "properties": {
            "size": {
              "type": "string",
              "pattern": "^[0-9]+(GB|TB)$"
            },
            "storage_class": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "outputs": {
    "ip_address": {
      "type": "string",
      "description": "Primary IP address assigned once Realized."
    },
    "hostname": {
      "type": "string",
      "description": "Resolvable hostname."
    },
    "instance_id": {
      "type": "string",
      "description": "Provider-assigned instance identifier."
    }
  },
  "immutable": [
    "guest_os.type"
  ],
  "relationships": [
    {
      "kind": "depends_on",
      "target": "Network.IPAddress",
      "target_field": "address",
      "cardinality": "0..n",
      "description": "May consume one or more pre-allocated addresses."
    }
  ]
}
