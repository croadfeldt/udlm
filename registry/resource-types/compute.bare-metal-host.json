{
  "$id": "https://udlm.dev/registry/udlm/0.1/Compute.BareMetalHost/0.5.0",
  "conforms_to": "udlm/0.1",
  "uuid": "e4d414d7-249b-4e87-b0c2-9e44402ae768",
  "resource_type": "Compute.BareMetalHost",
  "version": "0.5.0",
  "family": "Resource",
  "portability": "portable",
  "status": "active",
  "metadata": {
    "display_name": "Bare Metal Host",
    "description": "A physical machine as a managed ASSET (the box itself) — the raw-resource form of compute. It can exist unallocated in inventory (lifecycle_state: available, §28), carries aggregate hardware capacity (cpu/memory/storage/gpu) as host attributes (§26; ADR-013 — components are not separate records), and is the thing that hosts workloads (VMs, containers, OSDs). An ALLOCATION of a host to a consumer is NOT a separate type — it is the Ownership/Allocation model (foundations/ownership-sharing-allocation.md §2.1 whole-allocation); a running 'instance' is a realized entity of this type. Grounded in Redfish ComputerSystem (inventory/system) + Metal3 BareMetalHost (provisioning lifecycle).",
    "maintainer": "udlm-registry",
    "origination_timestamp": "2026-06-27T00:31:44Z"
  },
  "spec": {
    "type": "object",
    "required": [],
    "properties": {
      "lifecycle_state": {
        "type": "string",
        "enum": [
          "available",
          "allocated",
          "retired"
        ],
        "default": "available",
        "description": "Allocation state (common-elements §6, §28). available = inventoried/unallocated raw asset; allocated = adopted into the managed lifecycle. Adopts Metal3 BareMetalHost.status.provisioning.state."
      },
      "composition_visibility": {
        "type": "string",
        "enum": [
          "opaque",
          "transparent",
          "selective"
        ],
        "default": "opaque",
        "description": "Whether the host's kept components (Hardware.NetworkInterface) are modeled as first-class entities vs a rollup (§26, entities/service-dependencies.md §11d); memory/CPU/disk/GPU are aggregate host attributes, not component records (ADR-013). opaque = rollup only."
      },
      "identity": {
        "type": "object",
        "description": "Chassis/system identity (SPEC-DESIGN-REQUIREMENTS §27).",
        "properties": {
          "serial_number": {
            "type": "string",
            "description": "System serial (Redfish ComputerSystem.SerialNumber)."
          },
          "asset_tag": {
            "type": "string",
            "description": "Org asset tag (Redfish AssetTag)."
          },
          "manufacturer": {
            "type": "string",
            "description": "Redfish Manufacturer."
          },
          "model": {
            "type": "string",
            "description": "Redfish Model."
          },
          "sku": {
            "type": "string",
            "description": "Redfish SKU."
          }
        }
      },
      "cpu": {
        "type": "object",
        "description": "Reconciled CPU rollup (§26) — aggregate host CPU. Adopts Redfish ProcessorSummary.",
        "properties": {
          "sockets": {
            "type": "integer",
            "minimum": 1,
            "description": "Populated sockets (Redfish ProcessorSummary.Count)."
          },
          "cores": {
            "type": "integer",
            "minimum": 1,
            "description": "Total physical cores (Redfish ProcessorSummary.CoreCount)."
          },
          "threads": {
            "type": "integer",
            "minimum": 1,
            "description": "Total logical processors (Redfish ProcessorSummary.LogicalProcessorCount)."
          }
        }
      },
      "memory": {
        "type": "object",
        "description": "Reconciled memory rollup (§26) — aggregate host memory. Adopts Redfish MemorySummary.",
        "properties": {
          "size": {
            "type": "string",
            "pattern": "^[0-9]+(MB|GB|TB|MiB|GiB|TiB)$",
            "description": "Total system memory, e.g. 64GB (Redfish MemorySummary.TotalSystemMemoryGiB)."
          }
        }
      },
      "storage": {
        "type": "object",
        "description": "Reconciled local-storage rollup (§26) — aggregate host local storage.",
        "properties": {
          "capacity": {
            "type": "string",
            "pattern": "^[0-9]+(MB|GB|TB|PB|MiB|GiB|TiB|PiB)$",
            "description": "Total raw local capacity."
          }
        }
      },
      "architecture": {
        "type": "string",
        "description": "System ISA, e.g. x86-64, aarch64."
      },
      "bios_version": {
        "type": "string",
        "description": "Firmware/BIOS version (Redfish BiosVersion)."
      }
    }
  },
  "outputs": {
    "power_state": {
      "type": "string",
      "description": "Observed power state — On | Off | PoweringOn | PoweringOff (Redfish ComputerSystem.PowerState). Drives shutdown/startup ordering for the dependency graph."
    },
    "management_address": {
      "type": "string",
      "description": "Reachable management endpoint (BMC/Redfish or host management IP) once Realized."
    }
  },
  "immutable": [
    "identity.serial_number"
  ],
  "relationships": [
    {
      "edge_type": "depends_on",
      "target": "Facility.PowerFeed",
      "cardinality": "0..n",
      "description": "Power source(s) the host draws from; the host stops before the feed in a reverse-topo shutdown."
    },
    {
      "edge_type": "references",
      "target": "Hardware.BiosProfile",
      "cardinality": "0..1",
      "description": "The desired BIOS/firmware profile this host converges to (drift = live BIOS != profile). Host-side declaration per the dependent-side rule."
    }
  ],
  "adopts": [
    {
      "standard": "Redfish",
      "version": "2024.4",
      "standard_name": "ComputerSystem",
      "role": "physical system inventory + power vocabulary (identity, processor/memory summary, PowerState)",
      "source": "https://www.dmtf.org/standards/redfish",
      "license": "DMTF",
      "license_compatibility": "compatible-reference",
      "disposition": "tier1_value"
    },
    {
      "standard": "Metal3",
      "version": "1.x",
      "standard_name": "BareMetalHost",
      "role": "bare-metal provisioning lifecycle + available/provisioned state",
      "source": "https://book.metal3.io/",
      "license": "Apache-2.0",
      "license_compatibility": "compatible-reference",
      "disposition": "tier1_value"
    }
  ],
  "aliases": [
    {
      "name": "Dedicated Host",
      "standard": "AWS",
      "note": "the physical-host asset; tenant instances run on it"
    },
    {
      "name": "Ironic node",
      "standard": "OpenStack",
      "note": "the managed bare-metal node"
    },
    {
      "name": "Bare Metal Server",
      "note": "common colloquial name"
    }
  ],
  "metering": {
    "dimensions": [
      {
        "name": "installed_cores",
        "unit": "cores",
        "cost_class": "capex",
        "source": {
          "kind": "field",
          "ref": "spec.cpu.cores"
        }
      },
      {
        "name": "installed_memory",
        "unit": "GB",
        "cost_class": "capex",
        "source": {
          "kind": "field",
          "ref": "spec.memory.size"
        }
      },
      {
        "name": "installed_storage",
        "unit": "GB",
        "cost_class": "capex",
        "source": {
          "kind": "field",
          "ref": "spec.storage.capacity"
        }
      },
      {
        "name": "provisioned_hours",
        "unit": "hours",
        "cost_class": "capex",
        "source": {
          "kind": "lifecycle",
          "ref": "realized_to_decommissioned"
        }
      },
      {
        "name": "power_kwh",
        "unit": "kWh",
        "cost_class": "opex",
        "source": {
          "kind": "telemetry",
          "metric": "host.power.draw"
        }
      }
    ]
  },
  "priced_by": {
    "information_provider_uuid": "c1a2b3d4-5e6f-4a7b-8c9d-0e1f2a3b4c5d",
    "external_model_id": "onprem-baremetal-2026-q3"
  }
}
