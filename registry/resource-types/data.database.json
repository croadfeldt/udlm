{
  "$id": "https://udlm.dev/registry/udlm/0.1/Data.Database/0.2.0",
  "conforms_to": "udlm/0.1",
  "uuid": "9c3488aa-00cb-40fa-b02d-fbf2c47acce9",
  "resource_type": "Data.Database",
  "version": "0.2.0",
  "family": "Resource",
  "entity_type": "Infrastructure Resource",
  "portability": "portable",
  "status": "active",
  "metadata": {
    "display_name": "Database",
    "description": "A managed relational database instance. Publishes connection outputs other resources bind to. Reconciled 2026-07-07 with the dcm-project catalog DatabaseSpec (#271): resources now required (matching their DatabaseSpec), and the storage/host relationships added so a database's data volume and placement are first-class edges.",
    "maintainer": "udlm-registry",
    "origination_timestamp": "2026-06-17T18:31:11Z"
  },
  "spec": {
    "type": "object",
    "required": [
      "engine",
      "version",
      "resources"
    ],
    "properties": {
      "engine": {
        "type": "string",
        "enum": [
          "postgres",
          "mysql"
        ],
        "description": "Database engine."
      },
      "version": {
        "type": "string",
        "description": "Engine version, e.g. 16. Allowed values are engine-dependent (see registry conditional-constraints, E3)."
      },
      "resources": {
        "type": "object",
        "properties": {
          "cpu": {
            "type": "number",
            "minimum": 0.25
          },
          "memory": {
            "type": "string",
            "pattern": "^[0-9]+(MB|GB)$"
          },
          "storage": {
            "type": "string",
            "pattern": "^[0-9]+(GB|TB)$"
          }
        }
      },
      "metadata": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        }
      }
    }
  },
  "outputs": {
    "connection_string": {
      "type": "string",
      "description": "Full connection string once Realized.",
      "sensitive": true
    },
    "host": {
      "type": "string",
      "description": "Database host."
    },
    "port": {
      "type": "integer",
      "description": "Listening port."
    },
    "username": {
      "type": "string",
      "description": "Provisioned application username."
    }
  },
  "relationships": [
    {
      "kind": "binds_to",
      "name": "data_volume",
      "adopted_from": "Kubernetes PersistentVolumeClaim",
      "target": "Storage.Volume",
      "cardinality": "0..1",
      "description": "The persistent volume backing the database's data directory (binds its volume_handle output). Ordering: the volume is realized before the database that stores on it."
    },
    {
      "kind": "contained_by",
      "name": "host",
      "target": "Compute.VirtualMachine",
      "cardinality": "0..1",
      "description": "The compute host/guest the database runs on, when self-hosted (vs a managed DBaaS provider)."
    },
    {
      "kind": "contained_by",
      "name": "cluster",
      "target": "Compute.Cluster",
      "cardinality": "0..1",
      "description": "The cluster the database runs on, when containerized/operator-managed."
    }
  ],
  "adopts": [
    {
      "standard": "FOCUS",
      "version": ">=1.3 <2.0",
      "role": "cost-and-usage data for this database",
      "identity_join": {
        "local_field": "uuid",
        "standard_column": "ResourceId"
      },
      "source": "https://focus.finops.org/",
      "license": "CC-BY-4.0",
      "license_compatibility": "compatible-reference"
    }
  ]
}
