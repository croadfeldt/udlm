{
  "$id": "https://udlm.dev/registry/udlm/0.1/Compute.Cluster/0.1.1",
  "conformsTo": "udlm/0.1",
  "uuid": "aa9b102d-ce5f-4921-82ba-ada25f44c6ea",
  "resourceType": "Compute.Cluster",
  "version": "0.1.1",
  "family": "Resource",
  "entityType": "Infrastructure Resource",
  "portability": "portable",
  "status": "active",
  "metadata": {
    "displayName": "Cluster",
    "description": "A managed Kubernetes/OpenShift cluster with one or more node pools and a network. Derived from OSAC's `cluster` fulfillment type (osac-project/fulfillment-service); the spec is the vendor-neutral Intent contract a provider (e.g. OSAC Cluster Fulfillment via RHACM + Hosted Control Planes) realizes. Targets Network.VirtualNetwork and Platform.Hub are forthcoming OSAC-derived types.",
    "maintainer": "udlm-registry",
    "originationTimestamp": "2026-06-17"
  },
  "spec": {
    "type": "object",
    "required": ["release", "nodePools"],
    "properties": {
      "release": { "type": "string", "description": "Platform release, e.g. 4.16 (OpenShift)." },
      "nodePools": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["name", "hostType", "count"],
          "properties": {
            "name": { "type": "string" },
            "hostType": { "type": "string", "description": "Resource Type name of the node shape (Compute.HostType — forthcoming)." },
            "count": { "type": "integer", "minimum": 1 }
          }
        }
      },
      "network": {
        "type": "object",
        "properties": {
          "podCIDR": { "type": "string", "pattern": "^[0-9./]+$" },
          "serviceCIDR": { "type": "string", "pattern": "^[0-9./]+$" }
        }
      }
    }
  },
  "immutable": ["network.podCIDR", "network.serviceCIDR"],
  "outputs": {
    "apiURL": { "type": "string", "description": "Cluster API server URL once Realized." },
    "consoleURL": { "type": "string", "description": "Web console URL." },
    "kubeconfig": { "type": "string", "description": "Admin kubeconfig.", "sensitive": true },
    "clusterId": { "type": "string", "description": "Provider-assigned cluster identifier." }
  },
  "relationships": [
    { "kind": "depends_on", "target": "Network.VirtualNetwork", "cardinality": "0..1", "description": "Realized onto a virtual network." },
    { "kind": "contained_by", "target": "Platform.Hub", "cardinality": "0..1", "description": "Provisioned and managed by a hub (ACM / Hosted Control Planes)." }
  ],
  "adopts": [
    {
      "standard": "FOCUS",
      "version": ">=1.3 <2.0",
      "role": "cost-and-usage data for this cluster",
      "identityJoin": { "localField": "uuid", "standardColumn": "ResourceId" },
      "source": "https://focus.finops.org/",
      "license": "CC-BY-4.0",
      "licenseCompatibility": "compatible-reference"
    },
    {
      "standard": "OpenCost",
      "version": "1.x",
      "role": "Kubernetes cost allocation (CPU/memory/idle)",
      "identityJoin": { "localField": "uuid", "standardColumn": "cluster" },
      "source": "https://opencost.io/",
      "license": "Apache-2.0",
      "licenseCompatibility": "compatible-reference"
    }
  ]
}
