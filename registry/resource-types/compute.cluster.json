{
  "$id": "https://udlm.dev/registry/udlm/0.1/Compute.Cluster/0.3.0",
  "conforms_to": "udlm/0.1",
  "uuid": "aa9b102d-ce5f-4921-82ba-ada25f44c6ea",
  "resource_type": "Compute.Cluster",
  "version": "0.3.0",
  "family": "Resource",
  "portability": "portable",
  "status": "active",
  "metadata": {
    "display_name": "Cluster",
    "description": "A managed Kubernetes/OpenShift cluster with one or more node pools and a network. Derived from OSAC's `cluster` fulfillment type (osac-project/fulfillment-service); the spec is the vendor-neutral Intent contract a provider (e.g. OSAC Cluster Fulfillment via RHACM + Hosted Control Planes) realizes. Targets Network.VirtualNetwork and Platform.Hub are forthcoming OSAC-derived types.",
    "maintainer": "udlm-registry",
    "origination_timestamp": "2026-06-17T19:57:00Z"
  },
  "spec": {
    "type": "object",
    "required": [
      "release",
      "node_pools"
    ],
    "properties": {
      "release": {
        "type": "string",
        "description": "Platform release, e.g. 4.16 (OpenShift)."
      },
      "node_pools": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": [
            "name",
            "host_type",
            "count"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "host_type": {
              "type": "string",
              "description": "Resource Type name of the node shape (Compute.HostType — forthcoming)."
            },
            "count": {
              "type": "integer",
              "minimum": 1
            },
            "instance_size": {
              "type": "string",
              "description": "Provider-neutral node size class (small|medium|large) — sizes each node in the pool; the provider maps it to a concrete node shape at naturalization (common-elements §2.2, ADR-014)."
            }
          }
        }
      },
      "network": {
        "type": "object",
        "properties": {
          "pod_cidr": {
            "type": "string",
            "pattern": "^[0-9./]+$"
          },
          "service_cidr": {
            "type": "string",
            "pattern": "^[0-9./]+$"
          }
        }
      }
    }
  },
  "immutable": [
    "network.pod_cidr",
    "network.service_cidr"
  ],
  "outputs": {
    "api_url": {
      "type": "string",
      "description": "Cluster API server URL once Realized."
    },
    "console_url": {
      "type": "string",
      "description": "Web console URL."
    },
    "kubeconfig": {
      "type": "string",
      "description": "Admin kubeconfig.",
      "sensitive": true
    },
    "cluster_id": {
      "type": "string",
      "description": "Provider-assigned cluster identifier."
    }
  },
  "relationships": [
    {
      "edge_type": "depends_on",
      "target": "Network.VirtualNetwork",
      "cardinality": "0..1",
      "description": "Realized onto a virtual network."
    },
    {
      "edge_type": "contained_by",
      "target": "Platform.Hub",
      "cardinality": "0..1",
      "description": "Provisioned and managed by a hub (ACM / Hosted Control Planes)."
    }
  ],
  "adopts": [
    {
      "standard": "FOCUS",
      "version": ">=1.3 <2.0",
      "role": "cost-and-usage data for this cluster",
      "identity_join": {
        "local_field": "uuid",
        "standard_column": "ResourceId"
      },
      "source": "https://focus.finops.org/",
      "license": "CC-BY-4.0",
      "license_compatibility": "compatible-reference",
      "disposition": "tier2_record"
    },
    {
      "standard": "OpenCost",
      "version": "1.x",
      "role": "Kubernetes cost allocation (CPU/memory/idle)",
      "identity_join": {
        "local_field": "uuid",
        "standard_column": "cluster"
      },
      "source": "https://opencost.io/",
      "license": "Apache-2.0",
      "license_compatibility": "compatible-reference",
      "disposition": "tier2_record"
    }
  ]
}
