{
  "$id": "https://udlm.dev/registry/udlm/0.1/Network.DHCPScope/0.3.0",
  "conforms_to": "udlm/0.1",
  "uuid": "bb2b301f-b5d9-4d5e-b9bf-7d9a4bb6c1ff",
  "resource_type": "Network.DHCPScope",
  "version": "0.3.0",
  "family": "Resource",
  "entity_type": "Infrastructure Resource",
  "portability": "portable",
  "status": "active",
  "metadata": {
    "display_name": "DHCP Scope",
    "description": "A DHCP address scope \u2014 a subnet's dynamic pool(s), options, and reservations. Grounded in the DHCP protocol concepts (RFC 2131 / RFC 8415). The concrete pool/option/lease model is provider config (any DHCP provider \u2014 Kea, dnsmasq, ISC DHCP, a cloud DHCP), projected not dictated; UDLM carries the neutral subnet + the graph edges. UDLM does not prescribe DHCP as the way to serve addresses \u2014 an address's origin is a field on Network.IPAddress (static/dhcp/link-layer/random).",
    "maintainer": "udlm-registry",
    "origination_timestamp": "2026-06-27T00:38:59Z"
  },
  "spec": {
    "type": "object",
    "required": [
      "subnet"
    ],
    "properties": {
      "subnet": {
        "type": "string",
        "description": "Scope subnet in CIDR (common-elements: cidr), e.g. 10.0.90.0/24."
      },
      "ip_family": {
        "type": "string",
        "enum": [
          "ipv4",
          "ipv6"
        ],
        "default": "ipv4",
        "description": "Address family (common-elements: ip_family)."
      },
      "pools": {
        "type": "array",
        "description": "Dynamic allocation ranges within the subnet (DHCP).",
        "items": {
          "type": "object",
          "required": [
            "start",
            "end"
          ],
          "properties": {
            "start": {
              "type": "string",
              "description": "First address of the range."
            },
            "end": {
              "type": "string",
              "description": "Last address of the range."
            }
          }
        }
      },
      "options": {
        "type": "object",
        "description": "Common DHCP options (RFC 2132).",
        "properties": {
          "router": {
            "type": "string",
            "description": "Default gateway (option 3)."
          },
          "dns_servers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "DNS servers (option 6)."
          },
          "domain_name": {
            "type": "string",
            "description": "Domain name (option 15)."
          }
        }
      },
      "lease_time": {
        "type": "integer",
        "minimum": 1,
        "description": "Default lease time in seconds."
      }
    }
  },
  "outputs": {
    "reservations": {
      "type": "array",
      "description": "DERIVED \u2014 not authored here. A projection of every Network.IPAddress(allocation: static) bound to a Hardware.NetworkInterface (its MAC) contained by a host (its hostname), within this scope. The reservation truth lives on the IPAddress records (ADR-023); a DHCP provider renders its reservations/leases from this set."
    }
  },
  "relationships": [
    {
      "kind": "depends_on",
      "target": "Compute.BareMetalHost",
      "cardinality": "0..n",
      "name": "dhcp_server_host",
      "description": "Host(s) running the DHCP server(s) serving this scope (e.g. an HA pair)."
    },
    {
      "kind": "depends_on",
      "target": "Compute.VirtualMachine",
      "cardinality": "0..n",
      "name": "dhcp_server_vm",
      "description": "DHCP server(s) hosted on VMs."
    }
  ],
  "adopts": [
    {
      "standard": "RFC-2131",
      "version": "2131",
      "standard_name": "subnet",
      "role": "DHCPv4 scope / pool / lease vocabulary",
      "source": "https://www.rfc-editor.org/rfc/rfc2131",
      "license": "IETF-Trust",
      "license_compatibility": "compatible-reference",
      "disposition": "tier1_value"
    },
    {
      "standard": "ISC-Kea",
      "version": "2.x",
      "standard_name": "subnet4",
      "role": "reference realization \u2014 one DHCP provider's subnet/pool/reservation model (MPL-2.0, referenced by name only, not the type's grounding)",
      "source": "https://kea.readthedocs.io/",
      "license": "MPL-2.0",
      "license_compatibility": "reference-only",
      "disposition": "tier1_value"
    }
  ],
  "aliases": [
    {
      "name": "DHCP Pool",
      "note": "common term for the dynamic range"
    },
    {
      "name": "Scope",
      "standard": "Microsoft",
      "note": "Windows DHCP 'scope'"
    }
  ]
}
