{
  "$id": "https://udlm.dev/registry/udlm/0.1/Storage.Cluster/0.3.0",
  "conforms_to": "udlm/0.1",
  "uuid": "21b5da18-94c1-44af-a09b-ecd1e1a38a65",
  "resource_type": "Storage.Cluster",
  "version": "0.3.0",
  "family": "Resource",
  "entity_type": "Composite",
  "portability": "portable",
  "lifecycle_archetype": "provisioning",
  "status": "active",
  "lifecycle": {
    "states": [
      "Intent",
      "Requested",
      "Realized",
      "Discovered"
    ],
    "decommission": "Provider tears down the storage cluster; Discovered reflects absent. Destroying a cluster destroys every pool/volume provisioned from it \u2014 so decommission is DATA-DESTRUCTIVE and must follow its volumes/pools in order."
  },
  "metadata": {
    "display_name": "Storage Cluster",
    "description": "A vendor-neutral distributed storage cluster that serves block, file, and/or object storage. The concrete technology (Ceph, etc.) is the PROVIDER, declared on the instance and in adopts[] \u2014 never in the type name. Consumers bind to the typed protocol outputs (storage classes / endpoints), not to the implementation. Grounded in SNIA Swordfish (StorageSystem) with Rook CephCluster as a reference realization.",
    "maintainer": "udlm-registry",
    "origination_timestamp": "2026-06-27T00:38:59Z"
  },
  "spec": {
    "type": "object",
    "required": [
      "protocols"
    ],
    "properties": {
      "protocols": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "block",
            "file",
            "object"
          ]
        },
        "description": "Storage access protocols the cluster serves (Ceph: block=RBD, file=CephFS, object=RGW/S3)."
      },
      "capacity": {
        "type": "object",
        "description": "Cluster capacity (Swordfish capacity model).",
        "properties": {
          "total": {
            "type": "string",
            "pattern": "^[0-9]+(GB|TB|PB|GiB|TiB|PiB)$",
            "description": "Total raw capacity."
          },
          "usable": {
            "type": "string",
            "pattern": "^[0-9]+(GB|TB|PB|GiB|TiB|PiB)$",
            "description": "Usable capacity after data-protection overhead."
          }
        }
      },
      "data_protection": {
        "type": "object",
        "description": "Redundancy scheme (Swordfish data-protection).",
        "properties": {
          "scheme": {
            "type": "string",
            "enum": [
              "replication",
              "erasure-coding"
            ],
            "description": "Protection method."
          },
          "replicas": {
            "type": "integer",
            "minimum": 1,
            "description": "Replica count when scheme=replication (e.g. 3)."
          }
        }
      }
    }
  },
  "outputs": {
    "block_storage_class": {
      "type": "string",
      "description": "Block (e.g. RBD) storage-class consumers provision volumes from."
    },
    "file_storage_class": {
      "type": "string",
      "description": "Shared-file (e.g. CephFS) storage-class."
    },
    "object_endpoint": {
      "type": "string",
      "description": "S3-compatible object endpoint (e.g. RGW)."
    }
  },
  "relationships": [
    {
      "kind": "depends_on",
      "target": "Compute.VirtualMachine",
      "cardinality": "0..n",
      "name": "node_vm",
      "description": "Storage nodes/OSDs hosted on VMs (the cluster needs a quorum of these up)."
    },
    {
      "kind": "depends_on",
      "target": "Compute.BareMetalHost",
      "cardinality": "0..n",
      "name": "node_host",
      "description": "Storage nodes/OSDs hosted on bare-metal hosts."
    }
  ],
  "adopts": [
    {
      "standard": "SNIA-Swordfish",
      "version": "1.2",
      "standard_name": "StorageSystem",
      "role": "distributed storage system / capacity / data-protection vocabulary",
      "source": "https://www.snia.org/forums/smi/swordfish",
      "license": "SNIA",
      "license_compatibility": "compatible-reference"
    },
    {
      "standard": "Rook",
      "version": "1.x",
      "standard_name": "CephCluster",
      "role": "reference realization (Ceph) \u2014 cluster shape, protocols, storage classes",
      "source": "https://rook.io/",
      "license": "Apache-2.0",
      "license_compatibility": "compatible-reference"
    }
  ]
}
