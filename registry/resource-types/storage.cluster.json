{
  "$id": "https://udlm.dev/registry/udlm/0.1/Storage.Cluster/0.1.0",
  "conformsTo": "udlm/0.1",
  "uuid": "21b5da18-94c1-44af-a09b-ecd1e1a38a65",
  "resourceType": "Storage.Cluster",
  "version": "0.1.0",
  "family": "Resource",
  "entityType": "Composite",
  "portability": "portable",
  "status": "active",
  "metadata": {
    "displayName": "Storage Cluster",
    "description": "A vendor-neutral distributed storage cluster that serves block, file, and/or object storage. The concrete technology (Ceph, etc.) is the PROVIDER, declared on the instance and in adopts[] — never in the type name. Consumers bind to the typed protocol outputs (storage classes / endpoints), not to the implementation. Grounded in SNIA Swordfish (StorageSystem) with Rook CephCluster as a reference realization.",
    "maintainer": "udlm-registry",
    "origination_timestamp": "2026-06-26"
  },
  "spec": {
    "type": "object",
    "required": ["protocols"],
    "properties": {
      "protocols": {
        "type": "array",
        "items": { "type": "string", "enum": ["block", "file", "object"] },
        "description": "Storage access protocols the cluster serves (Ceph: block=RBD, file=CephFS, object=RGW/S3)."
      },
      "capacity": {
        "type": "object",
        "description": "Cluster capacity (Swordfish capacity model).",
        "properties": {
          "total": { "type": "string", "pattern": "^[0-9]+(GB|TB|PB|GiB|TiB|PiB)$", "description": "Total raw capacity." },
          "usable": { "type": "string", "pattern": "^[0-9]+(GB|TB|PB|GiB|TiB|PiB)$", "description": "Usable capacity after data-protection overhead." }
        }
      },
      "dataProtection": {
        "type": "object",
        "description": "Redundancy scheme (Swordfish data-protection).",
        "properties": {
          "scheme": { "type": "string", "enum": ["replication", "erasure-coding"], "description": "Protection method." },
          "replicas": { "type": "integer", "minimum": 1, "description": "Replica count when scheme=replication (e.g. 3)." }
        }
      }
    }
  },
  "outputs": {
    "blockStorageClass": { "type": "string", "description": "Block (e.g. RBD) storage-class consumers provision volumes from." },
    "fileStorageClass": { "type": "string", "description": "Shared-file (e.g. CephFS) storage-class." },
    "objectEndpoint": { "type": "string", "description": "S3-compatible object endpoint (e.g. RGW)." }
  },
  "relationships": [
    { "kind": "depends_on", "target": "Compute.VirtualMachine", "cardinality": "0..n", "description": "Storage nodes/OSDs hosted on VMs (the cluster needs a quorum of these up)." },
    { "kind": "depends_on", "target": "Compute.BareMetalHost", "cardinality": "0..n", "description": "Storage nodes/OSDs hosted on bare-metal hosts." }
  ],
  "adopts": [
    {
      "standard": "SNIA-Swordfish",
      "version": "1.2",
      "standardName": "StorageSystem",
      "role": "distributed storage system / capacity / data-protection vocabulary",
      "source": "https://www.snia.org/forums/smi/swordfish",
      "license": "SNIA",
      "licenseCompatibility": "compatible-reference"
    },
    {
      "standard": "Rook",
      "version": "1.x",
      "standardName": "CephCluster",
      "role": "reference realization (Ceph) — cluster shape, protocols, storage classes",
      "source": "https://rook.io/",
      "license": "Apache-2.0",
      "licenseCompatibility": "compatible-reference"
    }
  ]
}
